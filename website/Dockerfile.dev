# Development Dockerfile for Angular App inside website folder
FROM node:22-alpine

WORKDIR /app

# Copy package files and install dependencies
COPY package*.json ./
RUN npm install

# Copy application source code
COPY . .

# Expose Angular dev server port
EXPOSE 4200

# Start dev server bound to 0.0.0.0 for container access
CMD ["npx", "ng", "serve", "--host", "0.0.0.0", "--poll", "2000"]
