# Development Dockerfile for Angular App with Hot Reloading inside website folder
FROM node:22-alpine

WORKDIR /app

# Copy package files and install dependencies
COPY package*.json ./
RUN npm install --legacy-peer-deps

# Copy application source code
COPY . .

# Expose Angular dev server port
EXPOSE 4200

# Start dev server bound to 0.0.0.0 with polling for instant hot reload on file changes
CMD ["npx", "ng", "serve", "--host", "0.0.0.0", "--poll", "1000", "--allowed-hosts"]
