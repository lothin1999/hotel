# Compiled & Build Outputs
/dist
/tmp
/out-tsc
/bazel-out
/.angular/cache
/coverage
__screenshots__/

# Node Dependencies
/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment & Secrets
.env
.env.*
!.env.example
.env.local

# IDEs & Editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.history/*

# Visual Studio Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/mcp.json

# Operating System & System Files
.DS_Store
Thumbs.db
desktop.ini
