# Root Development Dockerfile for Velour Hotel Manage
FROM node:22-alpine

WORKDIR /app/website

# Copy package files from website directory
COPY website/package*.json ./
RUN npm install

# Copy website source code
COPY website/ ./

# Expose Angular dev server port
EXPOSE 4200

# Run dev server
CMD ["npx", "ng", "serve", "--host", "0.0.0.0", "--poll", "2000"]
